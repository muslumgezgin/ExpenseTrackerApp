@page "/Error"
@using System.Diagnostics

<PageTitle>Hata</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
    <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Style="font-size:80px; color:#cf6679;" />
    <MudText Typo="Typo.h4" Class="mt-4" Color="Color.Error">Bir Hata Oluştu</MudText>
    <MudText Color="Color.Secondary" Class="mt-2 mb-2">
        İsteğiniz işlenirken beklenmeyen bir hata oluştu.
    </MudText>
    @if (ShowRequestId)
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-6">
            Request ID: <code>@RequestId</code>
        </MudText>
    }
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/"
               StartIcon="@Icons.Material.Outlined.Home">
        Ana Sayfaya Dön
    </MudButton>
</MudContainer>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    [PersistentState]
    private string? RequestId { get; set; }

    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized()
    {
        RequestId ??= Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }
}
