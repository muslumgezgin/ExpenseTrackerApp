@page "/"
@inject ExpenseTracker.Web.Services.ExpenseApiService ExpenseApi
@using System.Globalization
@using ExpenseTracker.Agent.Models

<PageTitle>Dashboard</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}

<MudText Typo="Typo.h4" GutterBottom="true">📊 @_currentMonth</MudText>

<MudGrid>

    @* Budget Summary *@
    <MudItem xs="12" sm="6" lg="4">
        @if (_breakdown is not null)
        {
            var b = _breakdown.Budget;
            var pct = b.Limit > 0 ? Math.Min((double)(b.TotalSpent / b.Limit * 100m), 100) : 0;
            <MudCard Elevation="2" Style="height:100%">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">💰 Budget Status</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
                        <MudText Typo="Typo.body2">Spent</MudText>
                        <MudText Typo="Typo.body2">
                            <strong>@FormatUSD(b.TotalSpent)</strong> / @FormatUSD(b.Limit)
                        </MudText>
                    </MudStack>
                    <MudProgressLinear Value="@pct"
                                       Color="@(b.IsOverBudget ? Color.Error : pct > 75 ? Color.Warning : Color.Success)"
                                       Rounded="true" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.caption"
                             Color="@(b.IsOverBudget ? Color.Error : Color.Success)">
                        @if (b.IsOverBudget)
                        {
                            <span>⚠️ Over budget by @FormatUSD(Math.Abs(b.Remaining))!</span>
                        }
                        else
                        {
                            <span>Remaining: @FormatUSD(b.Remaining)</span>
                        }
                    </MudText>
                </MudCardContent>
            </MudCard>
        }
        else if (!_loading)
        {
            <MudCard Elevation="2" Style="height:100%">
                <MudCardHeader>
                    <CardHeaderContent><MudText Typo="Typo.h6">💰 Budget Status</MudText></CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Color="Color.Secondary">No budget set for this month.</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                        You can tell the AI assistant "Set a $5000 budget for this month".
                    </MudText>
                </MudCardContent>
            </MudCard>
        }
    </MudItem>

    @* Category Breakdown *@
    <MudItem xs="12" sm="6" lg="4">
        <MudCard Elevation="2" Style="height:100%">
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">📂 Category Spending</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (_breakdown?.Categories is { Count: > 0 } cats)
                {
                    @foreach (var cat in cats.OrderByDescending(c => c.TotalSpent))
                    {
                        var catPct = _breakdown.Budget.TotalSpent > 0
                            ? Math.Min((double)(cat.TotalSpent / _breakdown.Budget.TotalSpent * 100m), 100)
                            : 0;
                        <div class="mb-2">
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">@cat.CategoryName</MudText>
                                <MudText Typo="Typo.body2">@FormatUSD(cat.TotalSpent)</MudText>
                            </MudStack>
                            <MudProgressLinear Value="@catPct" Color="Color.Primary" Rounded="true" Size="Size.Small" />
                        </div>
                    }
                }
                else if (!_loading)
                {
                    <MudText Color="Color.Secondary">No expenses recorded this month.</MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* AI Assistant Quick Access *@
    <MudItem xs="12" sm="12" lg="4">
        <MudCard Elevation="2" Style="height:100%">
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">🤖 AI Assistant</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2">
                    Use the AI assistant to add expenses, create budgets, or query categories.
                </MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/chat"
                           StartIcon="@Icons.Material.Outlined.SmartToy">
                    Start Chat
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    @* Recent Expenses Table *@
    <MudItem xs="12">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">🧾 Recent Expenses</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (_expenses.Count == 0 && !_loading)
                {
                    <MudText Color="Color.Secondary">No expenses recorded this month yet.</MudText>
                }
                else
                {
                    <MudTable Items="_expenses" Dense="true" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Date</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh>Category</MudTh>
                            <MudTh Style="text-align:right">Amount</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Date">@context.Date.ToString("dd MMM HH:mm")</MudTd>
                            <MudTd DataLabel="Description">@context.Description</MudTd>
                            <MudTd DataLabel="Category">
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">@context.CategoryName</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Amount" Style="text-align:right">
                                <strong>@FormatUSD(context.Amount)</strong>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

</MudGrid>

@code {
    private BudgetBreakdownModel? _breakdown;
    private List<ExpenseModel> _expenses = [];
    private bool _loading = true;
    private string _currentMonth = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _currentMonth = DateTime.Now.ToString("MMMM yyyy", CultureInfo.GetCultureInfo("en-US"));

        var now = DateTime.Now;
        var breakdownTask = ExpenseApi.GetBudgetBreakdownAsync(now.Month, now.Year);
        var expensesTask = ExpenseApi.GetExpensesAsync(now.Month, now.Year);

        await Task.WhenAll(breakdownTask, expensesTask);

        _breakdown = breakdownTask.Result;
        _expenses = expensesTask.Result;
        _loading = false;
    }

    private static string FormatUSD(decimal amount) =>
        amount.ToString("C", CultureInfo.GetCultureInfo("en-US"));
}
